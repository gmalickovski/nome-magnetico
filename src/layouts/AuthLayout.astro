---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<BaseLayout title={title} noIndex={true}>
  <div class="min-h-screen bg-[#131313] flex flex-col relative">

    <!-- Background global contínuo (unificando esquerda e direita) -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_18%_18%,rgba(212,175,55,0.14),transparent_30%),radial-gradient(circle_at_82%_78%,rgba(242,202,80,0.08),transparent_28%),linear-gradient(135deg,#131313_0%,#171411_46%,#0f0f0f_100%)]"></div>
      <div class="absolute inset-0 opacity-[0.06]" style="background-image: linear-gradient(rgba(242,202,80,0.18) 1px, transparent 1px), linear-gradient(90deg, rgba(242,202,80,0.14) 1px, transparent 1px); background-size: 48px 48px;"></div>
    </div>

    <header class="relative z-20 w-full">
      <div class="mx-auto flex w-full max-w-6xl items-center justify-between px-5 py-6 sm:px-8 lg:px-10 xl:px-0">
        <a href="/" class="inline-flex items-center hover:opacity-85 transition-opacity duration-300" aria-label="Nome Magnético">
          <img src="/logo-nm-header.svg" alt="Nome Magnético" class="h-9 w-auto lg:h-12" />
        </a>
        <a
          href="/"
          class="inline-flex items-center justify-center rounded-full border border-[#D4AF37]/40 bg-[#D4AF37]/10 px-5 py-2.5 text-sm font-bold text-[#D4AF37] shadow-lg shadow-[#D4AF37]/10 backdrop-blur transition-all duration-300 hover:border-[#D4AF37]/70 hover:bg-[#D4AF37]/15 hover:text-[#f2ca50]"
        >
          Voltar ao Início
        </a>
      </div>
    </header>

    <!-- Container do Layout Flexível (duas colunas com proporções equivalentes) -->
    <main class="relative z-10 mx-auto grid w-full max-w-6xl flex-1 grid-cols-1 items-start gap-10 px-5 pt-10 pb-8 sm:px-8 lg:grid-cols-2 lg:gap-8 lg:px-10 lg:pt-14 xl:px-0">

      <!-- ── Painel esquerdo — hero (oculto no mobile) ── -->
      <section class="hidden lg:flex w-full flex-col items-start justify-start">

        <!-- Conteúdo hero -->
        <div class="flex w-full max-w-lg flex-col items-start text-left">

        <h1 class="font-cinzel text-3xl xl:text-4xl font-bold text-[#e5e2e1] leading-tight mb-5">
          Seu nome carrega<br/>uma frequência.<br/>
          <span class="text-[#D4AF37]">Você conhece a sua?</span>
        </h1>

        <p class="text-gray-500 text-[15px] leading-relaxed max-w-sm mb-8">
          Numerologia cabalística aplicada ao seu nome de nascimento — revela bloqueios energéticos e aponta o caminho para a sua expressão máxima.
        </p>

        <!-- Separador dourado -->
        <div class="h-px w-16 bg-gradient-to-r from-[#D4AF37]/50 to-transparent mb-8"></div>

        <!-- Bullets de benefícios -->
        <ul class="space-y-4 text-sm">
          <li class="flex items-start gap-3">
            <span class="text-[#D4AF37] mt-0.5 flex-shrink-0">✦</span>
            <div>
              <span class="text-[#e5e2e1] font-medium">4 triângulos numerológicos</span>
              <p class="text-gray-600 text-xs mt-0.5">Vida, Pessoal, Social e Destino analisados em profundidade</p>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-[#D4AF37] mt-0.5 flex-shrink-0">✦</span>
            <div>
              <span class="text-[#e5e2e1] font-medium">Detecção de bloqueios energéticos</span>
              <p class="text-gray-600 text-xs mt-0.5">Sequências repetidas que travam sua expressão e relacionamentos</p>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-[#D4AF37] mt-0.5 flex-shrink-0">✦</span>
            <div>
              <span class="text-[#e5e2e1] font-medium">Sugestões de nomes harmoniosos</span>
              <p class="text-gray-600 text-xs mt-0.5">Variações sem bloqueios, compatíveis com sua Expressão e Destino</p>
            </div>
          </li>
        </ul>
      </div>
    </section>

    <!-- ── Painel direito — formulário ── -->
    <section class="flex w-full flex-col items-center justify-start">
      <div class="lg:hidden mb-6 max-w-sm text-center">
        <p class="font-cinzel text-2xl font-bold leading-tight text-[#e5e2e1]">
          Seu nome carrega uma frequência.
        </p>
      </div>

      <!-- Área central: formulário (centralizado de forma independente) -->
      <div class="flex w-full items-center justify-center">
        <div class="relative w-full max-w-[420px]">
          <!-- Sombra mais suave e realista atrás do card -->
          <div class="absolute inset-0 bg-black/40 rounded-2xl blur-[25px] pointer-events-none translate-y-6"></div>
          
          <!-- Card do formulário -->
          <div class="relative z-10">
            <slot />
          </div>
        </div>
      </div>

      <!-- Spacer inferior (Rodapé) -->
      <div class="pt-5 text-center">
          <p class="text-gray-700 text-xs">
            &copy; {new Date().getFullYear()} Nome Magnético. Todos os direitos reservados.
          </p>
      </div>

    </section>

    </main>
  </div>
</BaseLayout>
