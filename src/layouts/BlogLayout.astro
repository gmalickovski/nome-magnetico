---
/**
 * BlogLayout — layout dedicado ao blog.
 * Usa BaseLayout diretamente (sem os schemas da landing page)
 * e injeta os schemas corretos para Blog / BlogPosting.
 */
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
  description?: string;
  keywords?: string;
  ogImage?: string;
  // Article-specific
  isArticle?: boolean;
  articlePublishedTime?: string;
  articleModifiedTime?: string;
  articleAuthor?: string;
  articleSlug?: string;
  // Blog index
  activeCategory?: string;
}

const {
  title,
  description,
  keywords,
  ogImage = '/og-image.jpg',
  isArticle = false,
  articlePublishedTime,
  articleModifiedTime,
  articleAuthor = 'Claudia Delanni Vitoria',
  articleSlug,
} = Astro.props;

const SITE_URL = 'https://www.nomemagnetico.com.br';
const articleAuthorName = articleAuthor || 'Claudia Delanni Vitoria';

// Schema para o blog (índice)
const schemaBlog = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'Blog de Numerologia Cabalística — Nome Magnético',
  url: `${SITE_URL}/blog`,
  description: 'Artigos educativos sobre numerologia cabalística, bloqueios energéticos no nome, análise de nomes e desenvolvimento pessoal.',
  inLanguage: 'pt-BR',
  publisher: {
    '@type': 'Organization',
    name: 'Nome Magnético',
    url: SITE_URL,
    logo: {
      '@type': 'ImageObject',
      url: `${SITE_URL}/logo-nome-magnetico.png`,
    },
  },
};

// Schema para artigo individual
const schemaArticle = isArticle ? {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description: description ?? '',
  url: articleSlug ? `${SITE_URL}/blog/${articleSlug}` : `${SITE_URL}/blog`,
  datePublished: articlePublishedTime ?? '',
  dateModified: articleModifiedTime ?? articlePublishedTime ?? '',
  author: {
    '@type': 'Person',
    name: articleAuthorName,
    url: `${SITE_URL}/blog/sobre`,
  },
  publisher: {
    '@type': 'Organization',
    name: 'Nome Magnético',
    url: SITE_URL,
    logo: {
      '@type': 'ImageObject',
      url: `${SITE_URL}/logo-nome-magnetico.png`,
    },
  },
  image: ogImage.startsWith('http') ? ogImage : `${SITE_URL}${ogImage}`,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': articleSlug ? `${SITE_URL}/blog/${articleSlug}` : `${SITE_URL}/blog`,
  },
  inLanguage: 'pt-BR',
} : null;

const schemaBreadcrumb = isArticle && articleSlug ? {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Início', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${SITE_URL}/blog` },
    { '@type': 'ListItem', position: 3, name: title, item: `${SITE_URL}/blog/${articleSlug}` },
  ],
} : null;
---

<BaseLayout
  title={title}
  description={description}
  keywords={keywords}
  ogImage={ogImage}
  ogType={isArticle ? 'article' : 'website'}
  articlePublishedTime={articlePublishedTime}
  articleModifiedTime={articleModifiedTime}
>
  <Fragment slot="head">
    <script is:inline>
      (function(){
        try {
          var s = localStorage.getItem('blog-theme');
          var sys = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          document.documentElement.setAttribute('data-blog-theme', s || sys);
        } catch(e) {}
      })();
    </script>
    <style>
      /* TOC lateral: scrollável via roda do mouse, sem scrollbar visível.
         Quando o ponteiro está sobre o índice → roda rola o índice.
         Quando está sobre o artigo → roda rola a página. */
      .toc-nav { scrollbar-width: none; -ms-overflow-style: none; }
      .toc-nav::-webkit-scrollbar { display: none; }
    </style>
  </Fragment>
  {!isArticle && <script type="application/ld+json" set:html={JSON.stringify(schemaBlog)} />}
  {isArticle && schemaArticle && <script type="application/ld+json" set:html={JSON.stringify(schemaArticle)} />}
  {isArticle && schemaBreadcrumb && <script type="application/ld+json" set:html={JSON.stringify(schemaBreadcrumb)} />}
  <slot />
</BaseLayout>
