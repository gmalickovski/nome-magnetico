---
import AppLayout from '../../layouts/AppLayout.astro';
import { hasActiveSubscription, hasAnySubscription } from '../../backend/db/subscriptions';
import { createUserClient, supabase } from '../../backend/db/supabase';
const user = Astro.locals.user;
if (!user) return Astro.redirect('/auth/login');

// Desabilitar cache para o botÃ£o voltar do navegador nÃ£o repuxar dados velhos
Astro.response.headers.set('Cache-Control', 'no-store, no-cache, must-revalidate, proxy-revalidate');
Astro.response.headers.set('Pragma', 'no-cache');
Astro.response.headers.set('Expires', '0');

import FreeUsedModal from '../../frontend/components/app/FreeUsedModal';
import { FreePDFAutoGenerator } from '../../frontend/components/app/FreePDFAutoGenerator';
import { MailWarning } from '../../frontend/components/app/MailWarning';
import { DashboardCheckoutButton } from '../../frontend/components/app/DashboardCheckoutButton';
import { getHqPricesAndPromo, type PriceInfo } from '../../backend/payments/prices';
import { InitialAnalysisModal } from '../../frontend/components/app/InitialAnalysisModal';

// Funções de numerologia locais para cálculo instantâneo da análise gratuita do lead
import { calcularTodosTriangulos, detectarBloqueios } from '../../backend/numerology/triangle';
import {
  calcularExpressao,
  calcularDestino,
  calcularMotivacao,
  calcularImpressao,
  calcularMissao,
} from '../../backend/numerology/numbers';
import {
  detectarLicoesCarmicas,
  detectarTendenciasOcultas,
  mapearFrequencias,
  calcularDebitosCarmicos,
} from '../../backend/numerology/karmic';
import { avaliarCompatibilidade } from '../../backend/numerology/harmonization';
import { calcularScore } from '../../backend/numerology/score';

// Verifica parÃ¢metros de URL
const showFreeUsedModal   = Astro.url.searchParams.get('free_used') === 'true';
const showCheckoutSuccess = Astro.url.searchParams.get('checkout') === 'success';
const checkoutProduct     = Astro.url.searchParams.get('produto') ?? null;

// Verificar admin e dados do perfil
let isAdmin     = false;
let profileData: any = null;
let freeAnalysisId: string | null = null;
let freeAnalysis: any = null;
let bestSocialAnalysis: any = null;

const _client = createUserClient(Astro.locals.accessToken ?? '');

try {
  const { data: profile } = await _client
    .from('profiles').select('*').eq('id', user.id).single();
  isAdmin = profile?.role === 'admin';
  profileData = profile;
} catch {}

const needsEmailConfirmation = !(
  profileData?.email_verified_at ||
  user.user_metadata?.email_verified_at
);

// Busca anÃ¡lise gratuita concluÃ­da para exibir botÃ£o de download
try {
  const { data: foundFreeAnalysis } = await _client
    .from('analyses')
    .select('id, nome_completo, score, bloqueios, status')
    .or('is_free.eq.true,product_type.eq.analise_gratuita')
    .eq('user_id', user.id)
    .eq('status', 'complete')
    .order('created_at', { ascending: false })
    .limit(1)
    .maybeSingle();
  freeAnalysis = foundFreeAnalysis;
  freeAnalysisId = foundFreeAnalysis?.id ?? null;
} catch {}

// Sincronização automática de lead por e-mail para novas contas
let leadNome: string | null = null;
let leadData: string | null = null;
let showOnboardingModal = false;

if (!freeAnalysisId && user.email) {
  try {
    const { data: lead } = await supabase
      .from('free_analyses_leads')
      .select('id, nome_completo, data_nascimento')
      .eq('email', user.email.toLowerCase().trim())
      .order('created_at', { ascending: false })
      .limit(1)
      .maybeSingle();

    if (lead) {
      leadNome = lead.nome_completo;
      const parts = lead.data_nascimento.split('-');
      const formattedBirthDate = parts.length === 3 ? `${parts[2]}/${parts[1]}/${parts[0]}` : lead.data_nascimento;
      leadData = formattedBirthDate;

      // 1. Calcular a numerologia localmente (sem chamar IA)
      const todosTriangulos = calcularTodosTriangulos(lead.nome_completo, formattedBirthDate);
      const bloqueios = detectarBloqueios(todosTriangulos);
      const expressao = calcularExpressao(lead.nome_completo);
      const destino = calcularDestino(formattedBirthDate);
      const motivacao = calcularMotivacao(lead.nome_completo);
      const impressao = calcularImpressao(lead.nome_completo);
      const missao = calcularMissao(lead.nome_completo, formattedBirthDate);
      const licoesCarmicas = detectarLicoesCarmicas(lead.nome_completo);
      const tendenciasOcultas = detectarTendenciasOcultas(lead.nome_completo);
      const debitosCarmicos = calcularDebitosCarmicos(formattedBirthDate, destino, motivacao, expressao);
      const frequencias = mapearFrequencias(lead.nome_completo);
      const score = calcularScore({
        bloqueios: bloqueios.length,
        licoesCarmicas: licoesCarmicas.length,
        tendenciasOcultas: tendenciasOcultas.length,
        debitosCarmicos: debitosCarmicos.length,
        debitosCarmicoFixos: debitosCarmicos.filter(d => d.fixo).length,
        compatibilidade: avaliarCompatibilidade(expressao, destino),
      });

      // 2. Criar a análise no banco como concluída (complete)
      const { data: newAnalysis, error: analysisError } = await supabase
        .from('analyses')
        .insert({
          user_id: user.id,
          product_type: 'analise_gratuita',
          nome_completo: lead.nome_completo,
          data_nascimento: lead.data_nascimento,
          numero_expressao: expressao,
          numero_destino: destino,
          numero_motivacao: motivacao,
          numero_missao: missao,
          numero_impressao: impressao,
          numero_personalidade: impressao,
          arcano_regente: todosTriangulos.vida.arcanoRegente,
          bloqueios: bloqueios,
          triangulo_vida: todosTriangulos.vida,
          triangulo_pessoal: todosTriangulos.pessoal,
          triangulo_social: todosTriangulos.social,
          triangulo_destino: todosTriangulos.destino,
          licoes_carmicas: licoesCarmicas,
          tendencias_ocultas: tendenciasOcultas,
          debitos_carmicos: debitosCarmicos,
          frequencias_numeros: {
            frequencias,
            ranking: {
              melhorNome: { nomeCompleto: lead.nome_completo },
              dataNascimento: lead.data_nascimento,
            },
          },
          score,
          is_free: true,
          status: 'complete',
          completed_at: new Date().toISOString(),
        })
        .select()
        .single();

      if (!analysisError && newAnalysis) {
        freeAnalysis = newAnalysis;
        freeAnalysisId = newAnalysis.id;
      } else if (analysisError) {
        console.error('[index.astro] Erro ao criar análise gratuita:', analysisError.message);
      }

      // Salva dados no profiles
      await supabase.from('profiles').update({
        birth_name: lead.nome_completo,
        birth_date: lead.data_nascimento,
        updated_at: new Date().toISOString(),
      }).eq('id', user.id);
    } else {
      // Se não há lead e não há análise, mostra o modal de onboarding
      showOnboardingModal = true;
    }
  } catch (e) {
    console.error('[index.astro] Erro ao sincronizar lead gratuito:', e);
    showOnboardingModal = true;
  }
}

// Admin: acesso total sem verificar subscriptions
const [hasNomeSocial, hasNomeBebe, hasNomeEmpresa] = isAdmin
  ? [true, true, true]
  : await Promise.all([
      hasActiveSubscription(user.id, 'nome_social'),
      hasActiveSubscription(user.id, 'nome_bebe'),
      hasActiveSubscription(user.id, 'nome_empresa'),
    ]);

const hasAnyAccess = hasNomeSocial || hasNomeBebe || hasNomeEmpresa;

try {
  const { data: foundBestSocial } = await _client
    .from('analyses')
    .select('id, nome_completo, score, bloqueios, status, frequencias_numeros, created_at')
    .eq('user_id', user.id)
    .eq('product_type', 'nome_social')
    .eq('status', 'complete')
    .order('score', { ascending: false, nullsFirst: false })
    .order('created_at', { ascending: false })
    .limit(1)
    .maybeSingle();
  bestSocialAnalysis = foundBestSocial;
} catch {}

// Detectar estado expirado (jÃ¡ comprou antes, mas nenhuma ativa)
const isExpired = !isAdmin && !hasAnyAccess && await hasAnySubscription(user.id);

const PRICE_UNAVAILABLE: PriceInfo = { cents: 0, formatted: 'Indisponível', hasDiscount: false };
const { prices, promotion } = await getHqPricesAndPromo().catch(() => ({ prices: {}, promotion: null }));
const priceMap = prices as Record<string, PriceInfo>;

function getScoreTheme(scoreValue: number | null | undefined) {
  const score = Math.max(0, Math.min(100, scoreValue ?? 0));
  if (score >= 90) {
    return {
      label: 'Excelente',
      color: '#34d399',
      border: 'rgba(16,185,129,0.34)',
      bg: 'rgba(16,185,129,0.06)',
      shadow: '0 0 42px rgba(16,185,129,0.12)',
      pillBg: 'rgba(16,185,129,0.12)',
      pillColor: '#6ee7b7',
    };
  }
  if (score >= 70) {
    return {
      label: 'Bom',
      color: '#34d399',
      border: 'rgba(16,185,129,0.30)',
      bg: 'rgba(16,185,129,0.05)',
      shadow: '0 0 42px rgba(16,185,129,0.10)',
      pillBg: 'rgba(16,185,129,0.10)',
      pillColor: '#6ee7b7',
    };
  }
  if (score >= 40) {
    return {
      label: 'Aceitável',
      color: '#f59e0b',
      border: 'rgba(245,158,11,0.36)',
      bg: 'rgba(245,158,11,0.07)',
      shadow: '0 0 42px rgba(245,158,11,0.12)',
      pillBg: 'rgba(245,158,11,0.13)',
      pillColor: '#fbbf24',
    };
  }
  if (score >= 20) {
    return {
      label: 'Não recomendado',
      color: '#f87171',
      border: 'rgba(248,113,113,0.38)',
      bg: 'rgba(248,113,113,0.07)',
      shadow: '0 0 42px rgba(248,113,113,0.14)',
      pillBg: 'rgba(248,113,113,0.14)',
      pillColor: '#fecaca',
    };
  }
  return {
    label: 'Crítico',
    color: '#ef4444',
    border: 'rgba(239,68,68,0.38)',
    bg: 'rgba(239,68,68,0.07)',
    shadow: '0 0 42px rgba(239,68,68,0.14)',
    pillBg: 'rgba(239,68,68,0.14)',
    pillColor: '#fca5a5',
  };
}

const featuredAnalysis = bestSocialAnalysis ?? freeAnalysis;
const featuredAnalysisId = featuredAnalysis?.id ?? null;
const featuredIsSocial = !!bestSocialAnalysis;
const featuredName =
  bestSocialAnalysis?.frequencias_numeros?.ranking?.melhorNome?.nomeCompleto
    ?? bestSocialAnalysis?.nome_completo
    ?? freeAnalysis?.nome_completo
    ?? '';
const featuredTheme = getScoreTheme(featuredAnalysis?.score);
const featuredBlockCount = featuredAnalysis?.bloqueios?.length ?? 0;

const products = [
  {
    id: 'nome_social',
    iconSvg: `<svg viewBox="0 0 24 24" aria-hidden="true" class="h-9 w-9" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l1.6 4.9L18.5 9.5l-4.9 1.6L12 16l-1.6-4.9-4.9-1.6 4.9-1.6L12 3Z"/><path d="M5 14l.8 2.2L8 17l-2.2.8L5 20l-.8-2.2L2 17l2.2-.8L5 14Z"/><path d="M19 13l.6 1.7 1.7.6-1.7.6-.6 1.7-.6-1.7-1.7-.6 1.7-.6L19 13Z"/></svg>`,
    name: 'Nome Social',
    description: 'Harmonize sua assinatura: descubra por que sua assinatura tem mais poder do que você imagina e qual Nome Social flui melhor.',
    href: '/app/analise/nome-social',
    infoHref: '/nome-social',
    hasAccess: hasNomeSocial,
    theme: {
      primary: '#D4AF37',
      accent: '#f2ca50',
      border: 'rgba(212,175,55,0.22)',
      borderHover: 'rgba(212,175,55,0.42)',
      bg: 'linear-gradient(145deg, rgba(212,175,55,0.10), rgba(255,255,255,0.035) 52%, rgba(0,0,0,0.12))',
      bgHover: 'linear-gradient(145deg, rgba(212,175,55,0.15), rgba(255,255,255,0.050) 52%, rgba(0,0,0,0.10))',
      shadow: 'rgba(212,175,55,0.16)',
      checkoutClass: 'inline-flex items-center justify-center rounded-xl bg-[#D4AF37]/10 border border-[#D4AF37]/30 text-[#D4AF37] text-sm font-bold px-4 py-2.5 hover:bg-[#D4AF37]/20 transition-all',
      infoClass: 'inline-flex items-center justify-center rounded-xl border border-white/10 px-4 py-2.5 text-sm font-bold text-gray-400 transition hover:border-[#D4AF37]/40 hover:text-[#D4AF37]',
    },
  },
  {
    id: 'nome_bebe',
    iconSvg: `<svg viewBox="0 0 24 24" aria-hidden="true" class="h-9 w-9" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 10.5h.01"/><path d="M15 10.5h.01"/><path d="M9.5 15c1.5 1.2 3.5 1.2 5 0"/><path d="M12 21a8 8 0 0 0 8-8c0-4.2-3.1-7.7-7.2-8"/><path d="M12 21a8 8 0 0 1-8-8c0-4.2 3.1-7.7 7.2-8"/><path d="M12 5c1.8 0 3-1 3-2.5C13.2 2.3 12 3.3 12 5Z"/></svg>`,
    name: 'Nome de Bebê',
    description: 'Encontre o nome ideal para seu filho com compatibilidade familiar.',
    href: '/app/analise/nome-bebe',
    infoHref: '/nome-bebe',
    hasAccess: hasNomeBebe,
    theme: {
      primary: '#C97B63',
      accent: '#E8A598',
      border: 'rgba(201,123,99,0.24)',
      borderHover: 'rgba(232,165,152,0.44)',
      bg: 'linear-gradient(145deg, rgba(201,123,99,0.12), rgba(255,255,255,0.035) 52%, rgba(0,0,0,0.12))',
      bgHover: 'linear-gradient(145deg, rgba(201,123,99,0.17), rgba(255,255,255,0.050) 52%, rgba(0,0,0,0.10))',
      shadow: 'rgba(201,123,99,0.17)',
      checkoutClass: 'inline-flex items-center justify-center rounded-xl bg-[#C97B63]/10 border border-[#C97B63]/30 text-[#C97B63] text-sm font-bold px-4 py-2.5 hover:bg-[#C97B63]/20 transition-all',
      infoClass: 'inline-flex items-center justify-center rounded-xl border border-white/10 px-4 py-2.5 text-sm font-bold text-gray-400 transition hover:border-[#C97B63]/40 hover:text-[#E8A598]',
    },
  },
  {
    id: 'nome_empresa',
    iconSvg: `<svg viewBox="0 0 24 24" aria-hidden="true" class="h-9 w-9" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 21h16"/><path d="M6 21V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v16"/><path d="M9 7h1"/><path d="M14 7h1"/><path d="M9 11h1"/><path d="M14 11h1"/><path d="M9 15h1"/><path d="M14 15h1"/></svg>`,
    name: 'Nome Empresarial',
    description: 'Avalie nomes de empresa alinhados ao destino do fundador.',
    href: '/app/analise/nome-empresa',
    infoHref: '/nome-empresarial',
    hasAccess: hasNomeEmpresa,
    theme: {
      primary: '#4A7FC1',
      accent: '#7FB3E8',
      border: 'rgba(74,127,193,0.24)',
      borderHover: 'rgba(127,179,232,0.44)',
      bg: 'linear-gradient(145deg, rgba(74,127,193,0.13), rgba(255,255,255,0.035) 52%, rgba(0,0,0,0.12))',
      bgHover: 'linear-gradient(145deg, rgba(74,127,193,0.19), rgba(255,255,255,0.050) 52%, rgba(0,0,0,0.10))',
      shadow: 'rgba(74,127,193,0.18)',
      checkoutClass: 'inline-flex items-center justify-center rounded-xl bg-[#4A7FC1]/10 border border-[#4A7FC1]/30 text-[#7FB3E8] text-sm font-bold px-4 py-2.5 hover:bg-[#4A7FC1]/20 transition-all',
      infoClass: 'inline-flex items-center justify-center rounded-xl border border-white/10 px-4 py-2.5 text-sm font-bold text-gray-400 transition hover:border-[#4A7FC1]/40 hover:text-[#7FB3E8]',
    },
  },
];
---

<AppLayout title="Meu Painel">
  {needsEmailConfirmation && user.email && (
    <MailWarning client:load email={user.email} />
  )}

  <div class="space-y-8">

    <!-- Banner: Pagamento confirmado -->
    {showCheckoutSuccess && (
      <div
        id="checkout-success-banner"
        class="relative bg-gradient-to-r from-[#D4AF37]/15 to-[#D4AF37]/8 rounded-2xl p-5 flex items-start justify-between gap-4 overflow-hidden"
      >
        <div class="absolute inset-0 bg-gradient-to-b from-[#D4AF37]/5 to-transparent pointer-events-none rounded-2xl"></div>
        <div class="relative flex items-start gap-3 flex-1">
          <span class="text-2xl flex-shrink-0 mt-0.5">ðŸŽ‰</span>
          <div>
            <h3 class="font-cinzel text-base font-bold text-[#D4AF37] mb-0.5">Pagamento confirmado!</h3>
            <p class="text-[#e5e2e1] text-sm leading-relaxed">
              Bem-vindo ao Nome Magnético. Seu acesso está liberado - escolha seu produto abaixo para começar.
            </p>
          </div>
        </div>
        <button
          id="dismiss-success-banner"
          class="relative text-gray-500 hover:text-white transition-colors flex-shrink-0 mt-0.5"
          aria-label="Fechar"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    )}
    {showCheckoutSuccess && (
      <script define:vars={{ _checkoutProduct: checkoutProduct }}>
        (function () {
          if (typeof window.gtag === 'function') {
            window.gtag('event', 'purchase_complete', _checkoutProduct ? { produto: _checkoutProduct } : undefined);
          }
          var banner = document.getElementById('checkout-success-banner');
          var dismissBtn = document.getElementById('dismiss-success-banner');
          function dismissBanner() {
            if (banner) {
              banner.style.transition = 'opacity 0.4s ease, max-height 0.5s ease, padding 0.5s ease, margin 0.5s ease';
              banner.style.opacity = '0';
              banner.style.maxHeight = '0';
              banner.style.padding = '0';
              banner.style.margin = '0';
              setTimeout(function () { if (banner && banner.parentNode) banner.parentNode.removeChild(banner); }, 500);
            }
            if (window.history && window.history.replaceState) {
              var url = new URL(window.location.href);
              url.searchParams.delete('checkout');
              url.searchParams.delete('produto');
              window.history.replaceState({}, '', url.toString());
            }
          }
          if (dismissBtn) dismissBtn.addEventListener('click', dismissBanner);
          setTimeout(dismissBanner, 8000);
        })();
      </script>
    )}

    <!-- Banner: Expirado -->
    {isExpired && (
      <div class="bg-red-500/10 border border-red-500/30 rounded-2xl p-6 flex flex-col md:flex-row items-center justify-between gap-4">
        <div>
          <h3 class="font-cinzel text-lg font-bold text-red-400 mb-1">
            Seu acesso expirou
          </h3>
          <p class="text-gray-400 text-sm">Renove para continuar realizando análises numerológicas completas.</p>
        </div>
        <a
          href="/comprar"
          class="flex-shrink-0 bg-[#D4AF37] text-[#1A1A1A] font-medium px-6 py-2.5 rounded-lg hover:bg-[#f2ca50] transition-all duration-300 hover:scale-[1.02] active:scale-[0.98]"
        >
          Renovar Acesso
        </a>
      </div>
    )}

    <!-- Banner: Novo usuÃ¡rio (nunca comprou) -->
    {false && !isAdmin && !hasAnyAccess && !isExpired && (
      <div class="bg-[#D4AF37]/10 border border-[#D4AF37]/30 rounded-2xl p-6 flex flex-col md:flex-row items-center justify-between gap-4">
        <div>
          <h3 class="font-cinzel text-lg font-bold text-[#D4AF37] mb-1">
            Comece sua jornada numerológica
          </h3>
          <p class="text-gray-400 text-sm">Adquira um dos produtos para realizar sua análise cabalística completa.</p>
        </div>
        <a
          href="/comprar"
          class="flex-shrink-0 bg-[#D4AF37] text-[#1A1A1A] font-medium px-6 py-2.5 rounded-lg hover:bg-[#f2ca50] transition-all duration-300 hover:scale-[1.02] active:scale-[0.98]"
        >
          Ver Todos os Produtos
        </a>
      </div>
    )}

    {featuredAnalysis && (
      <section
        class="rounded-3xl border bg-white/[0.03] p-5 md:p-7"
        style={`border-color:${featuredTheme.border}; box-shadow: inset 0 1px 0 rgba(255,255,255,0.03), ${featuredTheme.shadow};`}
      >
        <div class="grid gap-6 md:grid-cols-[1.2fr_0.8fr] md:items-center">
          <div class="order-2 md:order-1">
            <p class="mb-2 text-[10px] font-bold uppercase tracking-[0.22em] text-[#D4AF37]">
              {featuredIsSocial ? 'Melhor harmonização do Nome Social' : 'Análise gratuita de nascimento'}
            </p>
            <h2 class="font-cinzel text-2xl font-bold leading-tight text-[#e5e2e1] md:text-3xl">
              {featuredName}
            </h2>
            <p class="mt-2 text-sm leading-relaxed text-gray-500">
              {featuredIsSocial
                ? 'Este é o melhor resultado salvo nas suas harmonizações. Acesse o relatório completo, baixe a análise gratuita ou gere uma nova análise do Nome Social.'
                : 'Seu diagnóstico inicial está salvo. Baixe novamente o PDF ou avance para harmonizar seu nome.'}
            </p>
            <div class="mt-5 flex flex-col gap-3 sm:flex-row">
              {featuredIsSocial ? (
                <>
                  <a
                    href={`/app/resultado/${featuredAnalysisId}`}
                    class="inline-flex items-center justify-center rounded-xl border border-[#D4AF37]/35 bg-[#D4AF37]/10 px-5 py-2.5 text-sm font-bold text-[#D4AF37] transition hover:bg-[#D4AF37]/15"
                  >
                    Ver Harmonização
                  </a>
                  <FreePDFAutoGenerator
                    client:load
                    existingAnalysisId={freeAnalysisId}
                    autoRun={false}
                  />
                  <a
                    href="/app/analise/nome-social"
                    class="inline-flex items-center justify-center rounded-xl bg-[#D4AF37] px-5 py-2.5 text-sm font-bold text-[#131313] transition hover:bg-[#f2ca50]"
                  >
                    Nova harmonização
                  </a>
                </>
              ) : (
                <>
                  <FreePDFAutoGenerator
                    client:load
                    existingAnalysisId={freeAnalysisId}
                    autoRun={false}
                  />
                  {hasNomeSocial ? (
                    <a
                      href="/app/analise/nome-social"
                      class="inline-flex items-center justify-center rounded-xl bg-[#D4AF37] px-5 py-2.5 text-sm font-bold text-[#131313] transition hover:bg-[#f2ca50]"
                    >
                      Harmonizar meu Nome
                    </a>
                  ) : (
                    <DashboardCheckoutButton
                      client:load
                      product="nome_social"
                      priceInfo={priceMap.nome_social ?? PRICE_UNAVAILABLE}
                      promotion={promotion}
                      label="Harmonizar meu Nome"
                      className="inline-flex items-center justify-center rounded-xl bg-[#D4AF37] px-5 py-2.5 text-sm font-bold text-[#131313] transition hover:bg-[#f2ca50]"
                    />
                  )}
                </>
              )}
            </div>
          </div>

          {(() => {
            const theme = getScoreTheme(featuredAnalysis.score);
            const scoreVal = Math.max(0, Math.min(100, featuredAnalysis.score ?? 0));
            // Circunferência de raio 44 é 2 * PI * 44 = 276.46
            const circumference = 276.46;
            const strokeDashoffset = circumference * (1 - scoreVal / 100);
            return (
              <div class="relative flex items-center justify-center w-44 h-44 md:w-56 md:h-56 mx-auto order-1 md:order-2">
                <!-- SVG de Progresso Circular -->
                <svg class="absolute inset-0 w-full h-full transform -rotate-90" viewBox="0 0 100 100">
                  <!-- Círculo de Fundo -->
                  <circle
                    cx="50"
                    cy="50"
                    r="44"
                    fill="transparent"
                    stroke="rgba(255,255,255,0.03)"
                    stroke-width="4"
                  />
                  <!-- Círculo de Progresso -->
                  <circle
                    cx="50"
                    cy="50"
                    r="44"
                    fill="transparent"
                    stroke={theme.color}
                    stroke-width="4"
                    stroke-dasharray={circumference}
                    stroke-dashoffset={strokeDashoffset}
                    stroke-linecap="round"
                    style="transition: stroke-dashoffset 1.2s cubic-bezier(0.4, 0, 0.2, 1), stroke 0.4s ease;"
                  />
                </svg>

                <!-- Conteúdo Interno -->
                <div
                  class="flex flex-col items-center justify-center rounded-full w-[88%] h-[88%] bg-[#111111]"
                  style={`background:radial-gradient(circle at 50% 30%, ${theme.bg}, #111111 58%); box-shadow:${theme.shadow};`}
                >
                  <span class="font-cinzel text-5xl font-bold md:text-6xl" style={`color:${theme.color};`}>
                    {scoreVal}
                  </span>
                  <span class="mt-1 text-[10px] font-bold uppercase tracking-[0.18em] text-gray-500">
                    {featuredIsSocial ? 'Melhor score' : 'Score atual'}
                  </span>
                  <span
                    class="mt-2.5 rounded-full px-3 py-1 text-[9px] font-bold uppercase tracking-[0.12em]"
                    style={`background-color:${theme.pillBg}; color:${theme.pillColor};`}
                  >
                    {theme.label} · {featuredBlockCount} {featuredBlockCount === 1 ? 'bloqueio' : 'bloqueios'}
                  </span>
                </div>
              </div>
            );
          })()}
        </div>
      </section>
    )}

    {!freeAnalysisId && leadNome && leadData && (
      <div>
        <FreePDFAutoGenerator
          client:load
          existingAnalysisId={null}
          leadNome={leadNome}
          leadData={leadData}
          autoRun={true}
        />
      </div>
    )}

    <!-- Produtos -->
    <div>
      <h2 class="font-cinzel text-xl font-bold text-gray-100 mb-4">Seus Produtos</h2>
      <div class="grid md:grid-cols-3 gap-6">
        {products.map(product => {
          return product.hasAccess ? (
            <a
              data-product-id={product.id}
              href={product.href}
              class="product-card product-card-themed block group rounded-2xl border p-6 transition-all duration-300 hover:scale-[1.02] cursor-pointer"
              style={`--product-primary:${product.theme.primary}; --product-accent:${product.theme.accent}; --product-border:${product.theme.border}; --product-border-hover:${product.theme.borderHover}; --product-bg:${product.theme.bg}; --product-bg-hover:${product.theme.bgHover}; --product-shadow:${product.theme.shadow};`}
            >
              <div class="product-card-themed__icon mb-4 inline-flex h-14 w-14 items-center justify-center rounded-2xl transition-colors" set:html={product.iconSvg}></div>
              <h3 class="product-card-themed__title font-cinzel text-xl font-bold text-white mb-2 transition-colors">
                {product.name}
              </h3>
              <p class="text-gray-400 text-sm">{product.description}</p>
              <div class="mt-4 flex items-center justify-between">
                <span class="text-sm font-medium" style={`color:${product.theme.primary};`}>Iniciar análise</span>
                <span class:list={[
                  'rounded-full px-2.5 py-1 text-[11px] font-bold uppercase tracking-[0.14em]',
                  isAdmin
                    ? 'bg-purple-500/15 text-purple-300 ring-1 ring-purple-500/30'
                    : 'bg-emerald-500/12 text-emerald-300 ring-1 ring-emerald-500/25'
                ]}>
                  {isAdmin ? 'Admin' : 'Ativo'}
                </span>
              </div>
            </a>
          ) : isExpired ? (
            <div
              class="product-card-themed block group rounded-2xl border p-6 relative transition-all duration-300 hover:scale-[1.02]"
              style={`--product-primary:${product.theme.primary}; --product-accent:${product.theme.accent}; --product-border:rgba(255,255,255,0.10); --product-border-hover:${product.theme.borderHover}; --product-bg:rgba(255,255,255,0.03); --product-bg-hover:${product.theme.bg}; --product-shadow:${product.theme.shadow};`}
            >
              <div class="product-card-themed__lock absolute top-3 right-3 text-gray-600 transition-colors" aria-hidden="true">
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="11" width="14" height="10" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/></svg>
              </div>
              <div class="product-card-themed__icon mb-4 inline-flex h-14 w-14 items-center justify-center rounded-2xl opacity-70 transition-opacity group-hover:opacity-90" set:html={product.iconSvg}></div>
              <h3 class="product-card-themed__title font-cinzel text-xl font-bold text-gray-500 mb-2 transition-colors">
                {product.name}
              </h3>
              <p class="text-gray-600 text-sm">{product.description}</p>
              <div class="mt-5 flex flex-col gap-3 sm:flex-row">
                <DashboardCheckoutButton client:load product={product.id as any} priceInfo={priceMap[product.id] ?? PRICE_UNAVAILABLE} promotion={promotion} label="Renovar" className={product.theme.checkoutClass} />
                <a href={product.infoHref} class={product.theme.infoClass}>Mais informações</a>
              </div>
            </div>
          ) : (
            <div
              class="product-card-themed block group rounded-2xl border p-6 relative transition-all duration-300 hover:scale-[1.02]"
              style={`--product-primary:${product.theme.primary}; --product-accent:${product.theme.accent}; --product-border:rgba(255,255,255,0.10); --product-border-hover:${product.theme.borderHover}; --product-bg:rgba(255,255,255,0.03); --product-bg-hover:${product.theme.bg}; --product-shadow:${product.theme.shadow};`}
            >
              <div class="product-card-themed__lock absolute top-3 right-3 text-gray-600 transition-colors" aria-hidden="true">
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="11" width="14" height="10" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/></svg>
              </div>
              <div class="product-card-themed__icon mb-4 inline-flex h-14 w-14 items-center justify-center rounded-2xl opacity-70 transition-opacity group-hover:opacity-90" set:html={product.iconSvg}></div>
              <h3 class="product-card-themed__title font-cinzel text-xl font-bold text-gray-500 mb-2 transition-colors">
                {product.name}
              </h3>
              <p class="text-gray-600 text-sm">{product.description}</p>
              <p class="text-gray-500 text-xs mt-2 group-hover:text-gray-400 transition-colors">Ainda não adquirido</p>
              <div class="mt-5 flex flex-col gap-3 sm:flex-row">
                <DashboardCheckoutButton client:load product={product.id as any} priceInfo={priceMap[product.id] ?? PRICE_UNAVAILABLE} promotion={promotion} label="Adquirir" className={product.theme.checkoutClass} />
                <a href={product.infoHref} class={product.theme.infoClass}>Mais informações</a>
              </div>
            </div>
          )
        })}
        {isAdmin && (
          <a
            href="/app/admin-analise"
            class="product-card product-card-themed block group rounded-2xl border p-6 transition-all duration-300 hover:scale-[1.02] cursor-pointer"
            style="--product-primary:#bea5ff; --product-accent:#d7c6ff; --product-border:rgba(190,165,255,0.15); --product-border-hover:rgba(190,165,255,0.4); --product-bg:rgba(190,165,255,0.02); --product-bg-hover:rgba(190,165,255,0.06); --product-shadow:rgba(190,165,255,0.1);"
          >
            <div class="product-card-themed__icon mb-4 inline-flex h-14 w-14 items-center justify-center rounded-2xl transition-colors">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
              </svg>
            </div>
            <h3 class="product-card-themed__title font-cinzel text-xl font-bold text-white mb-2 transition-colors">
              Área do Analista
            </h3>
            <p class="text-gray-400 text-sm">Crie análises personalizadas em tempo real e emita PDFs na hora.</p>
            <div class="mt-4 flex items-center justify-between">
              <span class="text-sm font-medium text-[#bea5ff]">Acessar painel</span>
              <span class="rounded-full px-2.5 py-1 text-[11px] font-bold uppercase bg-purple-500/15 text-purple-300 ring-1 ring-purple-500/30">
                Exclusivo Admin
              </span>
            </div>
          </a>
        )}
      </div>
    </div>

  </div>
  
  {showFreeUsedModal && <FreeUsedModal client:only="react" />}
  {showOnboardingModal && <InitialAnalysisModal client:only="react" />}

  <style>
    .product-card-themed {
      border-color: var(--product-border);
      background: var(--product-bg);
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.035), 0 18px 55px rgba(0,0,0,0.28);
    }

    .product-card-themed:hover {
      border-color: var(--product-border-hover);
      background: var(--product-bg-hover);
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.055), 0 24px 70px var(--product-shadow);
    }

    .product-card-themed__icon {
      color: var(--product-primary);
      border: 1px solid var(--product-border);
      background: color-mix(in srgb, var(--product-primary) 13%, transparent);
    }

    .product-card-themed:hover .product-card-themed__icon {
      color: var(--product-accent);
      border-color: var(--product-border-hover);
      background: color-mix(in srgb, var(--product-primary) 18%, transparent);
    }

    .product-card-themed:hover .product-card-themed__title {
      color: var(--product-accent);
    }

    .product-card-themed:hover .product-card-themed__lock {
      color: var(--product-accent);
    }
  </style>

  <script define:vars={{ isAdmin }}>
    (function () {
      try {
        if (isAdmin) {
          localStorage.setItem('nm-user-role', 'admin');
        } else {
          localStorage.removeItem('nm-user-role');
        }
      } catch (e) {}
    })();
  </script>
</AppLayout>
