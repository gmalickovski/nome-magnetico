---
import AppLayout from '../../layouts/AppLayout.astro';
import AdminGeneralAnalysis from '../../frontend/components/app/AdminGeneralAnalysis';
import { createUserClient } from '../../backend/db/supabase';

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect('/auth/login');
}

// Desabilitar cache para o painel de administração
Astro.response.headers.set('Cache-Control', 'no-store, no-cache, must-revalidate, proxy-revalidate');
Astro.response.headers.set('Pragma', 'no-cache');
Astro.response.headers.set('Expires', '0');

let isAdmin = false;
let initialAnalyses: any[] = [];

try {
  const client = createUserClient(Astro.locals.accessToken ?? '');
  
  // 1. Validar papel de administrador de forma rigorosa
  const { data: profile } = await client
    .from('profiles')
    .select('role')
    .eq('id', user.id)
    .single();
    
  isAdmin = profile?.role === 'admin';
  
  // 2. Se não for admin, redirecionar de volta ao painel normal
  if (!isAdmin) {
    return Astro.redirect('/app');
  }

  // 3. (Removido: as análises do analista agora aparecem direto na listagem padrão)
} catch (err) {
  console.error('[admin-analise.astro] Falha ao autorizar admin ou carregar análises:', err);
  return Astro.redirect('/app');
}
---

<AppLayout title="Área do Analista" noPadding={true}>
  <div class="h-[calc(100vh-73px)] md:h-screen w-full flex flex-col bg-[#111111]">
    {/* REACT ISLAND */}
    <AdminGeneralAnalysis client:only="react" />
  </div>
</AppLayout>
