---
import { createUserClient } from '../../../backend/db/supabase';
import { hasUsedFreeAnalysis } from '../../../backend/db/analyses';

export interface Props {
  isAdmin?: boolean;
  showAnalisesNav?: boolean;
}

const user = Astro.locals.user;
let { isAdmin, showAnalisesNav } = Astro.props;

if (user && (isAdmin === undefined || showAnalisesNav === undefined)) {
  try {
    const client = createUserClient(Astro.locals.accessToken ?? '');
    const [profileRes, subsRes] = await Promise.all([
      client.from('profiles').select('role, is_test, test_ends_at').eq('id', user.id).single(),
      client.from('subscriptions').select('product_type').eq('user_id', user.id).gt('ends_at', new Date().toISOString()),
    ]);
    
    if (isAdmin === undefined) {
      isAdmin = profileRes.data?.role === 'admin';
    }
    
    if (showAnalisesNav === undefined) {
      let isTest = false;
      if (profileRes.data?.is_test) {
        const exp = profileRes.data.test_ends_at;
        isTest = exp === null || new Date(exp) > new Date();
      }
      let hasAnyActive = isAdmin || isTest || (subsRes.data?.length ?? 0) > 0;
      if (!hasAnyActive && !isAdmin) {
        const hasFreeAnalysis = await hasUsedFreeAnalysis(user.id);
        showAnalisesNav = isAdmin || hasAnyActive || hasFreeAnalysis;
      } else {
        showAnalisesNav = true;
      }
    }
  } catch {
    // fallback
    if (isAdmin === undefined) isAdmin = false;
    if (showAnalisesNav === undefined) showAnalisesNav = false;
  }
}

const pathname = Astro.url.pathname;
const isActive = (path: string) => pathname === path || pathname.startsWith(path + '/');

const navAppActive = isActive('/app') && !isActive('/app/analises') && !isActive('/app/resultado') && !isActive('/app/suporte') && !isActive('/app/analise') && !isActive('/app/admin-analise');
const navAnalisesActive = isActive('/app/analises') || isActive('/app/resultado');
const navSuporteActive = isActive('/app/suporte');
const navAnalistaActive = isActive('/app/admin-analise');
---

<nav class="md:hidden fixed bottom-0 left-0 w-full bg-[#111111]/95 backdrop-blur-xl border-t border-[#D4AF37]/20 z-50 flex items-center overflow-x-auto hide-scrollbar pt-2 px-2" style="padding-bottom: max(0.5rem, env(safe-area-inset-bottom))">
  <a href="/app" data-astro-prefetch="viewport" class={`flex-1 flex-shrink-0 min-w-[72px] flex flex-col items-center p-2 transition-all duration-200 active:scale-95 active:bg-[#D4AF37]/5 cursor-pointer touch-manipulation select-none ${navAppActive ? 'text-[#D4AF37]' : 'text-gray-500'}`}>
    <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg>
    <span class="text-[10px] font-medium tracking-wide">Produtos</span>
  </a>
  
  {showAnalisesNav && (
    <a href="/app/analises" data-astro-prefetch="viewport" class={`flex-1 flex-shrink-0 min-w-[72px] flex flex-col items-center p-2 transition-all duration-200 active:scale-95 active:bg-[#D4AF37]/5 cursor-pointer touch-manipulation select-none ${navAnalisesActive ? 'text-[#D4AF37]' : 'text-gray-500'}`}>
      <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
      <span class="text-[10px] font-medium tracking-wide">Análises</span>
    </a>
  )}
  
  {isAdmin && (
    <a href="/app/admin-analise" data-astro-prefetch="viewport" class={`flex-1 flex-shrink-0 min-w-[72px] flex flex-col items-center p-2 transition-all duration-200 active:scale-95 active:bg-[#D4AF37]/5 cursor-pointer touch-manipulation select-none ${navAnalistaActive ? 'text-[#D4AF37]' : 'text-gray-500'}`}>
      <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" /></svg>
      <span class="text-[10px] font-medium tracking-wide">Analista</span>
    </a>
  )}
  
  <a href="/app/suporte" data-astro-prefetch="viewport" class={`flex-1 flex-shrink-0 min-w-[72px] flex flex-col items-center p-2 transition-all duration-200 active:scale-95 active:bg-[#D4AF37]/5 cursor-pointer touch-manipulation select-none ${navSuporteActive ? 'text-[#D4AF37]' : 'text-gray-500'}`}>
    <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
    <span class="text-[10px] font-medium tracking-wide">Suporte</span>
  </a>
  
  <a href="/blog" target="_blank" rel="noopener noreferrer" class="flex-1 flex-shrink-0 min-w-[72px] flex flex-col items-center p-2 transition-all duration-200 active:scale-95 active:bg-white/5 cursor-pointer touch-manipulation select-none text-gray-500">
    <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9.5a2 2 0 00-.586-1.414l-4.5-4.5A2 2 0 0015.5 3H15m3 12h-3m3-4h-3m3-4h-3" /></svg>
    <span class="text-[10px] font-medium tracking-wide">Blog</span>
  </a>
</nav>

<style>
  a {
    -webkit-tap-highlight-color: transparent;
  }
</style>

<script is:inline>
  function setupMobileNav() {
    const navLinks = document.querySelectorAll('nav a');
    
    navLinks.forEach(link => {
      if (link.getAttribute('target') === '_blank' || link.getAttribute('href')?.startsWith('http')) return;
      
      link.addEventListener('click', () => {
        const href = link.getAttribute('href');
        if (!href || href === window.location.pathname) return;
        
        // Impedir cliques múltiplos/duplicados
        if (document.getElementById('mobile-nav-loading-bar')) return;
        
        // Efeito imediato de toque (escala e opacidade)
        link.style.transform = 'scale(0.92)';
        link.style.opacity = '0.75';
        
        // Criar barra de carregamento premium no topo (estilo YouTube/GitHub)
        const bar = document.createElement('div');
        bar.id = 'mobile-nav-loading-bar';
        bar.style.position = 'fixed';
        bar.style.top = '0';
        bar.style.left = '0';
        bar.style.height = '3px';
        bar.style.width = '0%';
        bar.style.backgroundImage = 'linear-gradient(to right, #f2ca50, #bea5ff, #f2ca50)';
        bar.style.zIndex = '99999';
        bar.style.transition = 'width 1.5s cubic-bezier(0.1, 0.8, 0.3, 1)';
        bar.style.boxShadow = '0 0 8px rgba(242, 202, 80, 0.6), 0 0 15px rgba(190, 165, 255, 0.4)';
        document.body.appendChild(bar);
        
        // Iniciar animação de progresso
        requestAnimationFrame(() => {
          bar.style.width = '90%';
        });
      });
    });
  }

  // Executa imediatamente e no carregamento completo
  setupMobileNav();
  document.addEventListener('DOMContentLoaded', setupMobileNav);
</script>
